  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -n api,vite -c blue,green \"npm run db:serve\" \"npm run dev\"",
    "build": "tsc -b && vite build",
