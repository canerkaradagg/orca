# Bu dosya şablondur. .env olarak kopyalayıp gerçek değerlerle doldurun. .env asla git'e eklenmemelidir.
#
# SQL Server – OrcaAlokasyon veritabanına bağlanır (giriş adı sunucuda tanımlı olan kullanıcı olmalı)
DB_SERVER=localhost
DB_NAME=OrcaAlokasyon
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ERP Integrator (B2BPortal ile aynı URL ve Connect body – token almak için)
ERP_INTEGRATOR_URL=http://localhost:1930
ERP_INTEGRATOR_DATABASE=OLKAV3
ERP_INTEGRATOR_USER_GROUP=OFIS
ERP_INTEGRATOR_USER=Integrator
ERP_INTEGRATOR_PASSWORD=your_erp_integrator_password

# API sunucusu portu (db:serve). 3001 doluysa 3002 yapın; Vite proxy bu portu kullanır.
# API_PORT=3002

# JWT Authentication – production'da güçlü, rastgele bir değer kullanın
JWT_SECRET=your-jwt-secret-change-in-production

# OrcaTrigger vb. servisler için internal API key (X-Internal-API-Key header). Boş bırakılırsa JWT gerekir.
# INTERNAL_SERVICE_API_KEY=your-secure-random-key

# CORS – Production'da virgülle ayrılmış izin verilen origin'ler (örn. https://orca.example.com, https://app.example.com). Boş = * (tüm origin'lere izin, sadece dev için).
# CORS_ALLOWED_ORIGINS=

# Frontend (Vite build'de API adresi – dev'de boş bırakın)
# VITE_API_BASE=

# Bakım raporu e-postası (Parametreler sayfasındaki MaintenanceReportEmail ile aynı adres kullanılır)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=your-email@example.com
